PORT=3000
JWT_SECRET=change_this_to_a_long_random_secret
DATA_DIR=./data
UPLOADS_DIR=./uploads

# Amazon SES SMTP configuration
# Replace region in host if needed:
# us-east-1 -> email-smtp.us-east-1.amazonaws.com
# SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username_here
# SMTP_PASS=your_smtp_password_here
# SMTP_FROM=otpsender@example.com

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=otpsender@example.com

# SES Identity API credentials (required for programmatic recipient verification)
# Note: SMTP_USER/SMTP_PASS cannot be used for SES API calls.
# SES_API_REGION=ap-southeast-2
# SES_API_ACCESS_KEY_ID=
# SES_API_SECRET_ACCESS_KEY=
# # Optional for temporary credentials:
# SES_API_SESSION_TOKEN=

# Optional
NODE_ENV=development
SEED_DEMO_DOCTORS=false

# Razorpay
# Keep test mode for local/dev usage. Live mode is blocked by server checks.
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
